
{
  "entities": {
    "College": {
      "title": "الكلية",
      "description": "تمثل الكلية الجامعية في النظام.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "اسم الكلية الرسمي" },
        "code": { "type": "string", "description": "رمز الكلية المختصر" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "code"]
    },
    "AcademicYear": {
      "title": "العام الدراسي",
      "description": "يمثل السنة الدراسية الجامعية.",
      "type": "object",
      "properties": {
        "label": { "type": "string", "description": "تسمية العام (مثلاً: 2023 / 2024)" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["label"]
    },
    "Department": {
      "title": "التخصص/القسم",
      "description": "يمثل القسم العلمي التابع لكلية معينة.",
      "type": "object",
      "properties": {
        "nameAr": { "type": "string", "description": "اسم القسم بالعربية" },
        "nameEn": { "type": "string", "description": "اسم القسم بالإنجليزية" },
        "code": { "type": "string", "description": "رمز القسم" },
        "collegeId": { "type": "string", "description": "معرف الكلية التابع لها" },
        "collegeName": { "type": "string", "description": "اسم الكلية للسهولة" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nameAr", "code", "collegeId"]
    },
    "Student": {
      "title": "الطالب",
      "description": "بيانات الطالب الأكاديمية الكاملة.",
      "type": "object",
      "properties": {
        "regId": { "type": "string", "description": "رقم القيد الجامعي" },
        "name": { "type": "string", "description": "الاسم الرباعي للطالب" },
        "collegeId": { "type": "string" },
        "collegeName": { "type": "string" },
        "departmentId": { "type": "string" },
        "departmentName": { "type": "string" },
        "academicYear": { "type": "string", "description": "السنة الدراسية المقيد بها" },
        "level": { "type": "string", "description": "المستوى الدراسي الحالي" },
        "admissionType": { "type": "string", "enum": ["عام", "موازي", "نفقة خاصة"] },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "joinDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["regId", "name", "collegeId", "departmentId", "level", "academicYear"]
    },
    "Subject": {
      "title": "المادة الدراسية",
      "description": "المادة العلمية المرفق اختباراتها في الأرشيف.",
      "type": "object",
      "properties": {
        "nameAr": { "type": "string", "description": "اسم المادة بالعربية" },
        "nameEn": { "type": "string", "description": "اسم المادة بالإنجليزية" },
        "departmentId": { "type": "string", "description": "معرف القسم التابع له" },
        "departmentName": { "type": "string" },
        "level": { "type": "string", "description": "المستوى المخصصة له المادة" },
        "term": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nameAr", "departmentId", "level"]
    },
    "Archive": {
      "title": "الملف المؤرشف",
      "description": "يمثل ورقة اختبار ممسوحة ضوئياً ومؤرشفة مباشرة في Firestore.",
      "type": "object",
      "properties": {
        "student_id": { "type": "string", "description": "رقم القيد المستخرج" },
        "student_name": { "type": "string", "description": "اسم الطالب المستخرج" },
        "subject_name": { "type": "string", "description": "اسم المادة المستخرج" },
        "file_data": { "type": "string", "description": "سلسلة Base64 للملف (يجب أن تكون < 800KB)" },
        "file_type": { "type": "string", "description": "نوع الملف (image/jpeg, application/pdf)" },
        "year": { "type": "string" },
        "term": { "type": "string" },
        "departmentId": { "type": "string" },
        "level": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["student_id", "file_data"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/colleges/{collegeId}": {
      "schema": "#/entities/College",
      "description": "مجموعة الكليات الجامعية"
    },
    "/academicYears/{yearId}": {
      "schema": "#/entities/AcademicYear",
      "description": "قائمة الأعوام الدراسية"
    },
    "/departments/{departmentId}": {
      "schema": "#/entities/Department",
      "description": "مجموعة الأقسام العلمية"
    },
    "/students/{studentId}": {
      "schema": "#/entities/Student",
      "description": "بيانات الطلاب المسجلين"
    },
    "/subjects/{subjectId}": {
      "schema": "#/entities/Subject",
      "description": "المواد الدراسية"
    },
    "/archives/{archiveId}": {
      "schema": "#/entities/Archive",
      "description": "الأرشيف المركزي للاختبارات (مخزن بـ Base64)"
    }
  }
}
